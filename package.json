{
  "name": "sitku",
  "private": true,
  "version": "2026.7.4",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/sanlinhtik3/sitku.git"
  },
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:desktop": "node electron/scripts/build-renderer.mjs",
    "desktop": "npm run build:desktop && electron electron/main.mjs",
    "desktop:dev": "node electron/scripts/dev.mjs",
    "build:dev": "vite build --mode development",
    "dist:mac": "npm run build:desktop && electron-builder --mac",
    "dist:mac:arm64": "npm run build:desktop && electron-builder --mac --arm64",
    "dist:mac:universal": "npm run build:desktop && electron-builder --mac --universal",
    "dist:win": "npm run build:desktop && electron-builder --win",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.sitku.app",
    "productName": "Sitku",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "asar": true,
    "publish": {
      "provider": "github",
      "owner": "sanlinhtik3",
      "repo": "sitku"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "icon": "public/pwa-512x512.png",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Sitku needs microphone access so the voice assistant can hear and talk to you.",
        "NSCameraUsageDescription": "Sitku needs camera access for photo and video attachments."
      }
    },
    "win": {
      "target": "nsis",
      "icon": "public/pwa-512x512.png"
    }
  },
